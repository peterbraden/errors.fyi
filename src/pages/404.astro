---
import Base from '../layouts/Base.astro';
import { getEntriesForCode } from '../lib/data';

// Pre-load the HTTP 404 entry so we can inline it for the /404 URL case.
const http404 = (await getEntriesForCode('404'))[0];
---

<Base title="Error Code" description="Error code lookup and unknown code reference.">
  <nav class="breadcrumb">
    <a href="/">errors.fyi</a>
    <span>/</span>
    <span id="breadcrumb-code">404</span>
  </nav>

  <!-- Shown when the URL is exactly /404 -->
  <div id="panel-code" hidden>
    <div class="code-badge">404</div>
    <h1>{http404.name}</h1>
    <div class="entries">
      <section class="entry">
        <p class="entry-desc">{http404.description}</p>
        {http404.references && http404.references.length > 0 && (
          <div class="entry-refs">
            <h3>References</h3>
            <ul>
              {http404.references.map((ref) => (
                <li><a href={ref} target="_blank" rel="noopener">{ref}</a></li>
              ))}
            </ul>
          </div>
        )}
      </section>
    </div>
  </div>

  <!-- Shown for any other missing URL -->
  <div id="panel-unknown" hidden>
    <div class="code-badge muted">?</div>
    <h1>Unknown error code</h1>
    <p>
      This code is not yet in the directory. If you know what it means,
      please <a href="https://github.com/bradenp1/errorcodes" target="_blank" rel="noopener">open a pull request</a>
      to add it.
    </p>
    <div class="contribute">
      <h2>How to contribute</h2>
      <p>
        Create a file at <code>data/&lt;namespace&gt;/&lt;code&gt;.md</code> with the following frontmatter:
      </p>
      <pre><code>---
name: Short name for the error
description: "One or two sentences describing what the error means."
references:
  - https://link-to-specification
---</code></pre>
      <p>
        See <a href="https://github.com/bradenp1/errorcodes/blob/main/data/README.md" target="_blank" rel="noopener">data/README.md</a>
        for the full schema, then open a pull request against <code>main</code>.
      </p>
    </div>
  </div>

  <div class="back">
    <a href="/">← browse all codes</a>
  </div>
</Base>

<script>
  const path = window.location.pathname.replace(/\/$/, '');
  const code = path.split('/').filter(Boolean).pop() ?? '';

  document.getElementById('breadcrumb-code')!.textContent = code || '404';

  if (path === '/404' || path === '') {
    document.getElementById('panel-code')!.removeAttribute('hidden');
  } else {
    document.getElementById('panel-unknown')!.removeAttribute('hidden');
  }
</script>

<style>
  .breadcrumb {
    font-size: 0.85rem;
    color: var(--muted);
    margin-bottom: 1.5rem;
    display: flex;
    gap: 0.4rem;
    align-items: center;
  }

  .code-badge {
    font-family: var(--mono);
    font-size: 3.5rem;
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
    margin-bottom: 0.5rem;
    letter-spacing: -0.03em;
  }

  .code-badge.muted { color: var(--muted); }

  h1 {
    font-size: 1.5rem;
    font-weight: 600;
    margin: 0 0 1.25rem;
  }

  /* Entry section */
  .entries { display: flex; flex-direction: column; gap: 2rem; }

  .entry {
    border-left: 2px solid var(--accent);
    padding-left: 1.25rem;
  }

  .entry-desc {
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 640px;
    margin: 0 0 0.75rem;
  }

  .entry-refs h3 {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin: 0 0 0.4rem;
  }

  .entry-refs ul { list-style: none; padding: 0; margin: 0; }
  .entry-refs li { font-size: 0.875rem; word-break: break-all; }

  /* Unknown panel */
  #panel-unknown p {
    color: var(--muted);
    max-width: 540px;
    margin: 0 0 1.5rem;
  }

  .contribute {
    margin-top: 2rem;
    padding: 1.5rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    max-width: 560px;
  }

  .contribute h2 {
    font-size: 0.95rem;
    font-weight: 600;
    margin: 0 0 0.75rem;
  }

  .contribute p {
    font-size: 0.875rem;
    color: var(--muted);
    margin: 0 0 0.75rem;
  }

  pre {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1rem;
    overflow-x: auto;
    margin: 0 0 0.75rem;
  }

  pre code {
    font-family: var(--mono);
    font-size: 0.8rem;
    color: var(--text);
  }

  .back {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    font-size: 0.875rem;
  }
</style>
