---
import Base from '../../layouts/Base.astro';
import { getNamespaces, getNamespace } from '../../lib/data';

export async function getStaticPaths() {
  const namespaces = await getNamespaces();
  return namespaces.map((ns) => ({ params: { namespace: ns.namespace } }));
}

const { namespace } = Astro.params;
const ns = await getNamespace(namespace);
if (!ns) return Astro.redirect('/');

// Group codes by their hundreds (1xx, 2xx, etc.) if numeric, otherwise ungrouped
const groups = ns.codes.reduce<Record<string, typeof ns.codes>>((acc, code) => {
  const num = parseInt(code.code, 10);
  const group = isNaN(num) ? 'Other' : `${Math.floor(num / 100)}xx`;
  (acc[group] ??= []).push(code);
  return acc;
}, {});
---

<Base title={ns.title} description={ns.description}>
  <nav class="breadcrumb">
    <a href="/">errors.fyi</a>
    <span>/</span>
    <span>{ns.title}</span>
  </nav>

  <h1>{ns.title}</h1>
  <p class="desc">{ns.description}</p>

  {ns.references && ns.references.length > 0 && (
    <p class="refs">
      Specification:{' '}
      {ns.references.map((ref, i) => (
        <>
          <a href={ref} target="_blank" rel="noopener">{ref}</a>
          {i < ns.references!.length - 1 && ', '}
        </>
      ))}
    </p>
  )}

  {Object.entries(groups).map(([group, codes]) => (
    <section>
      <h2>{group}</h2>
      <ul class="code-list">
        {codes.map((c) => (
          <li>
            <a href={`/${ns.namespace}/${c.code}/`}>
              <code>{c.code}</code>
              <span>{c.name}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  ))}
</Base>

<style>
  .breadcrumb {
    font-size: 0.85rem;
    color: var(--muted);
    margin-bottom: 1.5rem;
    display: flex;
    gap: 0.4rem;
    align-items: center;
  }

  h1 { font-size: 1.75rem; margin: 0 0 0.5rem; }

  .desc { color: var(--muted); margin: 0 0 0.5rem; }

  .refs {
    font-size: 0.8rem;
    color: var(--muted);
    margin: 0 0 2rem;
    word-break: break-all;
  }

  section { margin-bottom: 2rem; }

  h2 {
    font-family: var(--mono);
    font-size: 0.9rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 0.5rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.4rem;
  }

  .code-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .code-list li {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
  }

  .code-list a {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.65rem 1rem;
  }

  .code-list a:hover { text-decoration: none; background: var(--border); border-radius: 4px; }
  .code-list a:hover span { text-decoration: underline; }

  code {
    font-family: var(--mono);
    font-size: 0.9rem;
    color: var(--accent);
    min-width: 3.5rem;
    display: inline-block;
  }
</style>
