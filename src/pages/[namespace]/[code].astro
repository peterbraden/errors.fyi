---
import Base from '../../layouts/Base.astro';
import { getAllCodes, getNamespace } from '../../lib/data';

export async function getStaticPaths() {
  const codes = await getAllCodes();
  return codes.map((entry) => ({
    params: { namespace: entry.namespace, code: entry.code },
  }));
}

const { namespace, code } = Astro.params;
const { meta, codes } = await getNamespace(namespace);
const entry = codes.find((c) => c.code === code);

if (!entry) throw new Error(`Code ${code} not found in namespace ${namespace}`);

const description = entry.description;
---

<Base title={`${code} — ${meta.title}`} description={description}>
  <nav class="breadcrumb">
    <a href="/">errors.fyi</a>
    <span>/</span>
    <a href={`/ns/${namespace}/`}>{namespace}</a>
    <span>/</span>
    <span>{code}</span>
  </nav>

  <div class="code-header">
    <div class="code-badge">{code}</div>
    <a href={`/ns/${namespace}/`} class="ns-tag">{namespace}</a>
  </div>

  <h1>{entry.name}</h1>

  <p class="entry-desc">{entry.description}</p>

  {entry.numeric !== undefined && (
    <p class="entry-numeric">
      Numeric value: <a href={`/${entry.numeric}/`}><code>{entry.numeric}</code></a>
    </p>
  )}

  {entry.references && entry.references.length > 0 && (
    <div class="entry-refs">
      <h2>References</h2>
      <ul>
        {entry.references.map((ref) => (
          <li><a href={ref} target="_blank" rel="noopener">{ref}</a></li>
        ))}
      </ul>
    </div>
  )}

  <div class="back">
    <a href={`/${code}/`}>← all namespaces for {code}</a>
  </div>
</Base>

<style>
  .breadcrumb {
    font-size: 0.85rem;
    color: var(--muted);
    margin-bottom: 1.5rem;
    display: flex;
    gap: 0.4rem;
    align-items: center;
  }

  .code-header {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  .code-badge {
    font-family: var(--mono);
    font-size: 3.5rem;
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .ns-tag {
    font-family: var(--mono);
    font-size: 0.85rem;
    color: var(--muted);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.2rem 0.55rem;
    text-decoration: none;
    white-space: nowrap;
  }

  .ns-tag:hover {
    color: var(--text);
    border-color: var(--muted);
    text-decoration: none;
  }

  h1 {
    font-size: 1.5rem;
    font-weight: 600;
    margin: 0 0 1.5rem;
  }

  .entry-desc {
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 640px;
    margin: 0 0 0.75rem;
  }

  .entry-numeric {
    font-size: 0.875rem;
    color: var(--muted);
    margin: 0 0 0.75rem;
  }

  .entry-refs h2 {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin: 0 0 0.4rem;
    font-weight: 600;
  }

  .entry-refs ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .entry-refs li {
    font-size: 0.875rem;
    word-break: break-all;
  }

  .back {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    font-size: 0.875rem;
  }
</style>
