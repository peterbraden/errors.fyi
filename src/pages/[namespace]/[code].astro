---
import Base from '../../layouts/Base.astro';
import { getNamespaces, getNamespace } from '../../lib/data';

export async function getStaticPaths() {
  const namespaces = await getNamespaces();
  return namespaces.flatMap((ns) =>
    ns.codes.map((c) => ({
      params: { namespace: ns.namespace, code: c.code },
    }))
  );
}

const { namespace, code } = Astro.params;
const ns = await getNamespace(namespace);
if (!ns) return Astro.redirect('/');

const entry = ns.codes.find((c) => c.code === code);
if (!entry) return Astro.redirect(`/${namespace}/`);
---

<Base title={`${entry.code} ${entry.name}`} description={entry.description}>
  <nav class="breadcrumb">
    <a href="/">errors.fyi</a>
    <span>/</span>
    <a href={`/${ns.namespace}/`}>{ns.title}</a>
    <span>/</span>
    <span>{entry.code}</span>
  </nav>

  <div class="code-badge">{entry.code}</div>
  <h1>{entry.name}</h1>

  <p class="description">{entry.description}</p>

  {entry.references && entry.references.length > 0 && (
    <div class="references">
      <h2>References</h2>
      <ul>
        {entry.references.map((ref) => (
          <li><a href={ref} target="_blank" rel="noopener">{ref}</a></li>
        ))}
      </ul>
    </div>
  )}

  <div class="nav-links">
    <a href={`/${ns.namespace}/`}>← All {ns.title}</a>
  </div>
</Base>

<style>
  .breadcrumb {
    font-size: 0.85rem;
    color: var(--muted);
    margin-bottom: 1.5rem;
    display: flex;
    gap: 0.4rem;
    align-items: center;
  }

  .code-badge {
    font-family: var(--mono);
    font-size: 3.5rem;
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
    margin-bottom: 0.5rem;
    letter-spacing: -0.03em;
  }

  h1 {
    font-size: 1.5rem;
    margin: 0 0 1.25rem;
    font-weight: 600;
  }

  .description {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--text);
    max-width: 640px;
    margin: 0 0 2rem;
  }

  .references h2 {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin: 0 0 0.5rem;
  }

  .references ul {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
  }

  .references li {
    font-size: 0.875rem;
    word-break: break-all;
  }

  .nav-links {
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    font-size: 0.875rem;
  }
</style>
