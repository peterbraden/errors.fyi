---
import Base from '../layouts/Base.astro';
import { getNamespaces, getAllCodes } from '../lib/data';

const namespaces = await getNamespaces();
const allCodes = await getAllCodes();

// Group codes by namespace for the browse section
const byNamespace = namespaces.map((ns) => ({
  ...ns,
  codes: allCodes.filter((c) => c.namespace === ns.namespace),
}));
---

<Base title="Error Code Reference">
  <h1>errors.fyi</h1>
  <p class="tagline">
    A community directory of error codes. Each code has a canonical page — contribute via
    <a href="https://github.com/peterbraden/errors.fyi" target="_blank" rel="noopener">pull request</a>.
  </p>

  <form class="search" id="search">
    <input
      type="text"
      name="code"
      placeholder="404, ENOENT, …"
      autocomplete="off"
      autocorrect="off"
      autocapitalize="off"
      spellcheck="false"
      aria-label="Error code"
    />
    <button type="submit">Look up</button>
  </form>

  <script>
    document.getElementById('search')!.addEventListener('submit', (e) => {
      e.preventDefault();
      const code = (e.target as HTMLFormElement).code.value.trim();
      if (code) window.location.href = `/${code}/`;
    });
  </script>

  {byNamespace.map((ns) => (
    <section class="ns-section">
      <div class="ns-header">
        <h2>{ns.title}</h2>
        <span class="ns-count">{ns.codes.length} codes</span>
      </div>
      <p class="ns-desc">{ns.description}</p>

      <ul class="code-grid">
        {ns.codes.map((c) => (
          <li>
            <a href={`/${c.code}/`}>
              <code>{c.code}</code>
              <span>{c.name}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  ))}
</Base>

<style>
  h1 {
    font-family: var(--mono);
    font-size: 2rem;
    font-weight: 700;
    color: var(--accent);
    margin: 0 0 0.5rem;
    letter-spacing: -0.03em;
  }

  .tagline {
    color: var(--muted);
    margin: 0 0 1.5rem;
  }

  .search {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 3rem;
  }

  .search input {
    flex: 1;
    max-width: 320px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.5rem 0.75rem;
    font-family: var(--mono);
    font-size: 1rem;
    color: var(--text);
    outline: none;
  }

  .search input:focus {
    border-color: var(--accent);
  }

  .search button {
    background: var(--accent);
    color: #fff;
    border: none;
    border-radius: 4px;
    padding: 0.5rem 1rem;
    font-size: 0.9rem;
    cursor: pointer;
  }

  .search button:hover {
    opacity: 0.85;
  }

  .ns-section {
    margin-bottom: 3rem;
  }

  .ns-header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 0.25rem;
  }

  h2 {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0;
  }

  .ns-count {
    font-size: 0.8rem;
    color: var(--muted);
  }

  .ns-desc {
    font-size: 0.875rem;
    color: var(--muted);
    margin: 0 0 1rem;
  }

  .code-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1px;
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
  }

  .code-grid li {
    background: var(--surface);
  }

  .code-grid a {
    display: flex;
    flex-direction: column;
    padding: 0.6rem 0.85rem;
    height: 100%;
  }

  .code-grid a:hover {
    background: var(--border);
    text-decoration: none;
  }

  .code-grid a:hover span {
    text-decoration: underline;
  }

  .code-grid code {
    font-family: var(--mono);
    font-size: 0.9rem;
    color: var(--accent);
    display: block;
  }

  .code-grid span {
    font-size: 0.8rem;
    color: var(--muted);
    margin-top: 0.1rem;
  }
</style>
